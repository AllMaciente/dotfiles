/* ROUNDED THEME FOR ROFI */
/* Author: Newman Sanchez (https://github.com/newmanls) */
@import "~/.cache/huectl/rofi-colors.rasi"
* {
    font: "JetBrainsMono Nerd Font 12";

    background-color:   transparent;
    text-color:         @foreground;

    margin:     0px;
    padding:    0px;
    spacing:    0px;
}

window {
    location:       north;
    y-offset:       calc(50% - 176px);
    width:          480;
    border-radius:  24px;

      background-color:   @background-soft ;
}

mainbox {
    padding:    12px;
}

inputbar {
    background-color:   @background;
    border-color:       @color2;

    border:         2px;
    border-radius:  16px;

    padding:    8px 16px;
    spacing:    8px;
    children:   [ prompt, entry ];
}

prompt {
    padding: 1px 6px;
    background-color: @color2 ;
    text-color: @color8;
    border-radius: 16px;
}

entry {
    placeholder:        "Search";
    placeholder-color:  @color8;
}

message {
    margin:             12px 0 0;
    border-radius:      16px;
    border-color:       @color1;
    background-color:   @color1;
}

textbox {
    padding:    8px 24px;
}

listview {
    background-color:   transparent;

    margin:     12px 0 0;
    lines:      8;
    columns:    1;

    fixed-height: false;
}

element {
    padding:        8px 16px;
    spacing:        8px;
    border-radius:  16px;
}

element normal active {
    text-color: @color1;
}

element alternate active {
    text-color: @color3;
}

element selected normal, element selected active {
    background-color:   @color8;
}

element-icon {
    size:           1em;
    vertical-align: 0.5;
}

element-text {
    text-color: inherit;
}