(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps
  lshift

  a s d f

  u i o p
  h j k l
  n m , .

  ;
)

(defvar
  tap-time 200
  hold-time 200
)

(defalias
  ;; =========================
  ;; CAPS
  ;; tap = enter
  ;; hold = navigation layer
  ;; =========================

  caps-mod (tap-hold $tap-time $hold-time enter (layer-while-held nav))

  ;; =========================
  ;; REAL LEFT SHIFT
  ;; tap = shift
  ;; hold = numpad layer
  ;; =========================

  shift-num (tap-hold $tap-time $hold-time lshift (layer-while-held num))

  plus (macro S-=)
  star (macro S-8)
  minus -
  slash /

  ;; =========================
  ;; HOME ROW MODS
  ;; =========================

  a-mod (tap-hold $tap-time $hold-time a lmet)
  s-mod (tap-hold $tap-time $hold-time s lalt)
  d-mod (tap-hold $tap-time $hold-time d lsft)
  f-mod (tap-hold $tap-time $hold-time f lctl)

  j-mod (tap-hold $tap-time $hold-time j rctl)
  k-mod (tap-hold $tap-time $hold-time k rsft)
  l-mod (tap-hold $tap-time $hold-time l ralt)
  ;-mod (tap-hold $tap-time $hold-time ; rmet)
)

;; =========================
;; BASE
;; =========================

(deflayer base
  @caps-mod
  @shift-num

  @a-mod @s-mod @d-mod @f-mod

  u i o p
  h @j-mod @k-mod @l-mod
  n m , .

  @;-mod
)

;; =========================
;; NAVIGATION
;; =========================

(deflayer nav
  _
  _

  _ _ _ _

  home pgdn pgup end
  left down up right
  ins del bspc tab

  _
)

;; =========================
;; NUMPAD
;; =========================

(deflayer num
  _
  _

  _ _ _ _

  7 8 9 @star
  4 5 6 @minus
  1 2 3 @plus

  0
)
